/* 首页样式 */
.header {
  padding: 32rpx 0 24rpx;
}
.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text);
  display: block;
}
.header-subtitle {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
  display: block;
}

/* 总览网格 */
.overview-grid {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.overview-item {
  flex: 1;
  background: var(--color-card);
  border-radius: var(--radius);
  padding: 20rpx 12rpx;
  text-align: center;
  box-shadow: var(--shadow);
}
.overview-num {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text);
}
.overview-label {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-light);
  margin-top: 6rpx;
}
.highlight-saving .overview-num { color: #42A5F5; }
.highlight-buyable .overview-num { color: #66BB6A; }
.highlight-done .overview-num { color: #AB47BC; }

/* 金额卡片 */
.amount-cards {
  margin-bottom: 20rpx;
}
.amount-card {
  background: var(--color-card);
  border-radius: var(--radius);
  padding: 24rpx;
  box-shadow: var(--shadow);
}
.amount-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}
.amount-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}
.amount-value {
  font-size: 30rpx;
  font-weight: 600;
}
.amount-divider {
  height: 1rpx;
  background: var(--color-border);
  margin: 12rpx 0;
}

/* 快捷操作 */
.quick-actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 28rpx;
}
.action-btn {
  flex: 1;
  background: var(--color-card);
  border-radius: var(--radius);
  padding: 24rpx 12rpx;
  text-align: center;
  box-shadow: var(--shadow);
  font-size: 22rpx;
  color: var(--color-text);
}
.action-btn:active {
  background: var(--color-primary-light);
}
.action-icon {
  font-size: 40rpx;
  display: block;
  margin-bottom: 8rpx;
}

/* 版块 */
.section {
  margin-bottom: 28rpx;
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: 600;
}

/* 重点心愿卡片 */
.highlight-card {
  background: var(--color-card);
  border-radius: var(--radius);
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow);
}
.highlight-badge {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-bottom: 10rpx;
}
.badge-progress { background: #E8EAF6; color: #5C6BC0; }
.badge-warning { background: #FFF3E0; color: #F57C00; }
.badge-success { background: #E8F5E9; color: #43A047; }
.highlight-name {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
}
