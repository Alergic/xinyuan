<!--存款标签管理-->
<view class="container">
  <view class="card">
    <view class="card-title">🏷️ 存款标签</view>
    <view class="card-subtitle">给每笔存款打上来源标签（如工资、退款、省下的外卖钱…），统计页会按标签汇总，看看钱都是从哪存下来的 💪</view>

    <view wx:if="{{tags.length > 0}}" class="tag-list">
      <view wx:for="{{tags}}" wx:key="_id" class="tag-item">
        <view class="tag-left">
          <view class="tag-color" style="background:{{item.color}}"></view>
          <text class="tag-name">{{item.name}}</text>
        </view>
        <view class="tag-right">
          <view class="sort-btns">
            <view class="sort-btn {{index === 0 ? 'sort-btn-disabled' : ''}}" bindtap="moveUp" data-index="{{index}}">▲</view>
            <view class="sort-btn {{index === tags.length - 1 ? 'sort-btn-disabled' : ''}}" bindtap="moveDown" data-index="{{index}}">▼</view>
          </view>
          <view class="tag-action-btn" bindtap="editTag" data-tag="{{item}}">
            <text>✏️</text>
          </view>
          <view class="tag-action-btn" bindtap="onDeleteTag" data-tag="{{item}}">
            <text>🗑</text>
          </view>
        </view>
      </view>
    </view>

    <view wx:else class="empty-state">
      <text>还没有标签，点击下方按钮创建</text>
    </view>
  </view>

  <button class="btn btn-primary btn-block" bindtap="addTag">+ 新建标签</button>
</view>
