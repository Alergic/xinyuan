/* 存款池样式 */
.balance-card {
  background: linear-gradient(135deg, #5C6BC0, #7C8AE0);
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 20rpx;
  color: #fff;
  text-align: center;
}
.balance-label {
  font-size: 26rpx;
  opacity: 0.85;
  display: block;
}
.balance-amount {
  font-size: 64rpx;
  font-weight: 700;
  display: block;
  margin: 16rpx 0;
}
.balance-summary {
  display: flex;
  justify-content: space-around;
  font-size: 24rpx;
  opacity: 0.75;
}
.pool-actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.section {
  margin-bottom: 28rpx;
}
.section-header {
  margin-bottom: 16rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
}
.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: var(--color-card);
  border-radius: 8rpx;
  margin-bottom: 10rpx;
}
.record-amount {
  font-size: 30rpx;
  font-weight: 600;
}
.record-note {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
  display: block;
}

/* 标签 */
.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}
.tag-chip {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 500;
  border: 1rpx solid currentColor;
  opacity: 0.85;
}
