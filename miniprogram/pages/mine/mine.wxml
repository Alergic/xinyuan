<!--我的页面-->
<wxs module="util" src="../../utils/util.wxs"></wxs>
<view class="container">
  <!-- 用户信息 -->
  <view class="user-card">
    <view class="avatar-wrap">
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image class="avatar" src="{{avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
      </button>
    </view>
    <view class="user-info">
      <input class="nickname-input" type="nickname" value="{{nickname}}" placeholder="点击设置昵称" bindblur="onNicknameSave" />
      <input class="signature-input" value="{{signature}}" placeholder="写一句个性签名..." bindblur="onSignatureSave" maxlength="30" />
    </view>
  </view>

  <!-- 我的数据 -->
  <view class="card">
    <view class="card-title">📋 我的数据</view>
    <view class="menu-item" bindtap="goWishlist">
      <text>❤️ 我的心愿</text>
      <text class="text-light">{{stats.total_wishes}} 个 ›</text>
    </view>
    <view class="menu-item" bindtap="goSavings">
      <text>💰 存款记录</text>
      <text class="text-light">›</text>
    </view>
    <view class="menu-item" bindtap="goPool">
      <text>🏦 通用存款池</text>
      <text class="text-light">¥{{util.formatMoney(stats.pool_balance)}} ›</text>
    </view>
    <view class="menu-item" bindtap="goStats">
      <text>📊 统计</text>
      <text class="text-light">›</text>
    </view>
  </view>

  <!-- 设置 -->
  <view class="card">
    <view class="card-title">⚙️ 设置</view>
    <view class="menu-item" bindtap="goCategory">
      <text>📁 分类管理</text>
      <text class="text-light">›</text>
    </view>
    <view class="menu-item" bindtap="goTags">
      <text>🏷️ 存款标签</text>
      <text class="text-light">›</text>
    </view>
    <view class="menu-item" bindtap="subscribeReminder">
      <text>🔔 提醒设置</text>
      <text class="text-light">{{reminderSubscribed ? '已订阅' : '订阅提醒'}} ›</text>
    </view>
    <view class="menu-item" bindtap="showAbout">
      <text>ℹ️ 关于心愿计划</text>
      <text class="text-light">v1.0.0 ›</text>
    </view>
  </view>
</view>
