/* === 用户信息卡片 === */
.user-card {
  display: flex;
  justify-content: flex-start;
  align-items: center;
  padding: 32rpx;
  background: linear-gradient(135deg, #5C6BC0, #3949AB);
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  color: #fff;
  box-sizing: border-box;
}

/* 头像外层容器 — 控制占位与间距，不裁剪内容 */
.avatar-wrap {
  width: 80rpx;
  height: 80rpx;
  margin-right: 28rpx;
  flex-shrink: 0;
}

/* 头像按钮 — 透明方形点击区，圆角仅由图片控制 */
.avatar-btn {
  width: 100%;
  height: 100%;
  padding: 0;
  margin: 0;
  border: none;
  border-radius: 0;
  background: transparent;
  line-height: 0;
  box-sizing: border-box;
}
.avatar-btn::after {
  display: none;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: block;
}

/* 右侧文字组 — 左对齐 */
.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
  box-sizing: border-box;
  text-align: left;
}

.nickname-input {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  height: 50rpx;
  line-height: 50rpx;
  padding: 0;
  background: transparent;
  border: none;
  width: 100%;
  box-sizing: border-box;
  text-align: left;
}

.signature-input {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  height: 36rpx;
  line-height: 36rpx;
  padding: 0;
  margin-top: 4rpx;
  background: transparent;
  border: none;
  width: 100%;
  box-sizing: border-box;
  text-align: left;
}

/* === 菜单项 === */
.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--color-border);
  font-size: 28rpx;
  box-sizing: border-box;
}
.menu-item:last-child {
  border-bottom: none;
}
