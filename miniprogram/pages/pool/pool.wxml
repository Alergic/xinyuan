<!--通用存款池页-->
<wxs module="util" src="../../utils/util.wxs"></wxs>
<view class="container">
  <!-- 余额卡片 -->
  <view class="balance-card">
    <text class="balance-label">通用存款池余额</text>
    <text class="balance-amount">¥{{util.formatMoney(poolBalance)}}</text>
    <view class="balance-summary">
      <text>累计存入 ¥{{util.formatMoney(totalPoolIn)}}</text>
      <text>已分配 ¥{{util.formatMoney(totalAllocated)}}</text>
    </view>
  </view>

  <!-- 快捷操作 -->
  <view class="pool-actions">
    <button class="btn btn-primary flex-1" bindtap="addPoolSaving">💰 存入通用池</button>
    <button class="btn btn-outline flex-1" bindtap="allocate">📤 分配至心愿</button>
  </view>

  <!-- 分配面板 -->
  <view wx:if="{{showAllocate}}" class="card">
    <view class="card-title">分配通用池金额</view>
    <view class="form-group">
      <view class="form-label">选择心愿物品</view>
      <picker mode="selector" range="{{wishNames}}" bindchange="onWishSelect">
        <view class="picker-display">
          <text class="{{selectedWishName ? '' : 'text-light'}}">{{selectedWishName || '请选择'}}</text>
        </view>
      </picker>
    </view>
    <view class="form-group">
      <view class="form-label">分配金额（可用 ¥{{util.formatMoney(poolBalance)}}）</view>
      <input class="form-input" type="digit" placeholder="输入分配金额" value="{{allocAmount}}" bindinput="onAllocInput" />
    </view>
    <button class="btn btn-primary btn-block" bindtap="confirmAllocate">确认分配</button>
    <button class="btn btn-small btn-block mt-10" style="background:#F5F5F5" bindtap="cancelAllocate">取消</button>
  </view>

  <!-- 存款记录 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">通用池记录</text>
    </view>
    <view wx:if="{{records.length > 0}}">
      <view wx:for="{{records}}" wx:key="_id" class="record-item">
        <view class="record-left">
          <text class="record-amount text-{{item.saving_type === 'pool' ? 'success' : 'danger'}}">
            {{item.saving_type === 'pool' ? '+' : '-'}}¥{{util.formatMoney(item.amount)}}
          </text>
          <text class="record-note" wx:if="{{item.note}}">{{item.note}}</text>
        </view>
        <view style="display:flex;align-items:center">
          <text class="text-light" style="font-size:22rpx;margin-right:15rpx">{{item.saved_at_text}}</text>
          <text class="text-light" style="font-size:28rpx" bindtap="deletePoolRecord" data-id="{{item._id}}">🗑</text>
        </view>
      </view>
    </view>
    <view wx:else class="empty-state">
      <text class="text-light">暂无通用池记录</text>
    </view>
  </view>

  <!-- 分配记录 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">分配记录</text>
    </view>
    <view wx:if="{{allocations.length > 0}}">
      <view wx:for="{{allocations}}" wx:key="_id" class="record-item">
        <view class="record-left">
          <text class="record-amount text-primary">-¥{{util.formatMoney(item.amount)}}</text>
          <text class="record-note">分配给: {{item.item_name || '未知物品'}}</text>
        </view>
        <view style="display:flex;align-items:center">
          <text class="text-light" style="font-size:22rpx;margin-right:15rpx">{{item.allocated_at_text}}</text>
          <text class="text-warning" style="font-size:28rpx" bindtap="undoAllocation" data-id="{{item._id}}">↩</text>
        </view>
      </view>
    </view>
    <view wx:else class="empty-state">
      <text class="text-light">暂无分配记录</text>
    </view>
  </view>
</view>
