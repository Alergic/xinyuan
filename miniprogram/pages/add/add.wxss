/* 添加/编辑页 */
.picker-display {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius);
  background: #FAFAFA;
  font-size: 28rpx;
}
.priority-options {
  display: flex;
  gap: 16rpx;
}
.priority-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius);
  font-size: 26rpx;
  background: #FAFAFA;
}
.priority-btn.selected.high { border-color: #E53935; background: #FFEBEE; }
.priority-btn.selected.medium { border-color: #F57C00; background: #FFF3E0; }
.priority-btn.selected.low { border-color: #5C6BC0; background: #E8EAF6; }
.image-upload-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.image-upload-item {
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius);
  overflow: hidden;
  position: relative;
}
.image-upload-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border: 2rpx dashed var(--color-border);
  border-radius: var(--radius);
  background: #FAFAFA;
}
.uploaded-image {
  width: 100%;
  height: 100%;
}
.image-remove {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0,0,0,0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
  line-height: 1;
}

.clear-deadline {
  font-size: 24rpx;
  color: var(--color-danger);
  margin-left: auto;
}
