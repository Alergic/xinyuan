.card-subtitle {
  font-size: 24rpx;
  color: var(--color-text-light);
  margin-bottom: 20rpx;
}

.tag-list {
  margin-top: 16rpx;
}

.tag-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: var(--color-card);
  border-radius: var(--radius);
  margin-bottom: 12rpx;
  box-shadow: var(--shadow);
}

.tag-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.tag-color {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.tag-name {
  font-size: 28rpx;
  font-weight: 500;
}

.tag-right {
  display: flex;
  align-items: center;
  font-size: 32rpx;
}

.tag-action-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  margin-left: 8rpx;
}

.tag-action-btn:active {
  background: #F5F5F5;
}

.sort-btns {
  display: flex;
  flex-direction: column;
  margin-right: 4rpx;
}

.sort-btn {
  width: 44rpx;
  height: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: var(--color-text-light);
  border-radius: 6rpx;
  line-height: 1;
}

.sort-btn:active {
  background: #EEEEEE;
  color: var(--color-primary);
}

.sort-btn-disabled {
  color: #DDD;
  pointer-events: none;
}

.btn-block {
  margin-top: 24rpx;
}
